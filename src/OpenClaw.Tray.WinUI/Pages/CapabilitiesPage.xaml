<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.CapabilitiesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16" HorizontalAlignment="Stretch">

            <TextBlock x:Uid="CapabilitiesPage_TextBlock_10" Text="🖥️ This Computer" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock x:Name="HostnameText"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <!-- ═══ Security Level picker ═══ -->
            <Border x:Name="SecurityLevelCard"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16"
                    AutomationProperties.AutomationId="SecurityLevelCard">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE72E;" FontSize="16" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="🛡️ Security level" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <Border x:Name="LevelBadge" CornerRadius="10" Padding="8,1"
                                Background="{ThemeResource AccentFillColorTertiaryBrush}">
                            <TextBlock x:Name="LevelBadgeText" Text="Recommended" FontSize="11"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="How careful should this PC be when agents access it?"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="LockedDownButton" Grid.Column="0"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                Padding="12,10"
                                Click="OnLevelLockedDownClick"
                                AutomationProperties.AutomationId="LockedDownButton">
                            <StackPanel Spacing="2">
                                <TextBlock Text="🔒 Locked Down" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="Blocks program execution. Asks for camera/screen."
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="RecommendedButton" Grid.Column="1"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                Padding="12,10"
                                Click="OnLevelRecommendedClick"
                                AutomationProperties.AutomationId="RecommendedButton">
                            <StackPanel Spacing="2">
                                <TextBlock Text="⚖️ Recommended" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="Safe defaults for most people. Programs run in container."
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="TrustedButton" Grid.Column="2"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                Padding="12,10"
                                Click="OnLevelTrustedClick"
                                AutomationProperties.AutomationId="TrustedButton">
                            <StackPanel Spacing="2">
                                <TextBlock Text="🌐 Trusted (developer)" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="Programs run directly. Camera/screen pre-approved. Confirmation required to switch."
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <StackPanel x:Name="DriftPanel" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                        <FontIcon Glyph="&#xE946;" FontSize="14" Foreground="{ThemeResource SystemFillColorCautionBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="DriftText" VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <HyperlinkButton x:Name="ResetLevelButton" Content="Reset to base level"
                                         Click="OnResetLevelClick"
                                         Padding="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock x:Uid="CapabilitiesPage_TextBlock_15" Text="Device capabilities provided to agents via the gateway. Toggle what this computer can do."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap" MaxWidth="500" Margin="0,0,0,8"/>

            <!-- Capability toggles -->
            <ItemsRepeater x:Name="CapabilityRepeater">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinItemWidth="220" MinItemHeight="60"
                                       MinColumnSpacing="12" MinRowSpacing="8"/>
                </ItemsRepeater.Layout>
            </ItemsRepeater>

            <!-- Speech-to-Text settings (visible only when STT is enabled) -->
            <Border x:Name="SttCard" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,8,0,0"
                    Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="CapabilitiesPage_SttCardHeader" Text="🎤 Speech-to-Text" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock x:Uid="CapabilitiesPage_SttCardDescription"
                               Text="Recognizes microphone audio locally on this PC using Whisper. The model is downloaded once on first use."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                    <TextBlock x:Name="SttEngineHint"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                    <HyperlinkButton x:Name="SttMoreSettingsLink"
                                     x:Uid="CapabilitiesPage_SttMoreSettingsLink"
                                     Content="More voice settings…"
                                     Click="OnSttMoreSettingsClick"
                                     Padding="0"/>
                </StackPanel>
            </Border>

            <!-- Text-to-Speech settings (visible only when TTS is enabled) -->
            <Border x:Name="TtsCard" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,8,0,0"
                    Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="CapabilitiesPage_TtsCardHeader" Text="🔊 Text-to-Speech" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock x:Uid="CapabilitiesPage_TtsCardDescription"
                               Text="Default provider for tts.speak. Per-call provider/voiceId/model overrides this default."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                    <ComboBox x:Name="TtsProviderComboBox" x:Uid="CapabilitiesPage_TtsProviderComboBox" Header="Provider"
                              SelectionChanged="OnTtsProviderSelectionChanged">
                        <ComboBoxItem x:Uid="CapabilitiesPage_TtsProviderPiper" Content="Piper (local ML, recommended)" Tag="piper"/>
                        <ComboBoxItem x:Uid="CapabilitiesPage_TtsProviderWindows" Content="Windows built-in speech" Tag="windows"/>
                        <ComboBoxItem x:Uid="CapabilitiesPage_TtsProviderElevenLabs" Content="ElevenLabs" Tag="elevenlabs"/>
                    </ComboBox>
                    <StackPanel x:Name="TtsElevenLabsPanel" Spacing="6" Visibility="Collapsed">
                        <PasswordBox x:Name="TtsElevenLabsApiKeyBox"
                                     x:Uid="CapabilitiesPage_TtsElevenLabsApiKey"
                                     Header="ElevenLabs API key"
                                     LostFocus="OnTtsElevenLabsCommitted"/>
                        <TextBox x:Name="TtsElevenLabsVoiceIdBox"
                                 x:Uid="CapabilitiesPage_TtsElevenLabsVoiceId"
                                 Header="ElevenLabs voice ID"
                                 LostFocus="OnTtsElevenLabsCommitted"/>
                        <TextBox x:Name="TtsElevenLabsModelBox"
                                 x:Uid="CapabilitiesPage_TtsElevenLabsModel"
                                 Header="ElevenLabs model"
                                 PlaceholderText="eleven_multilingual_v2"
                                 LostFocus="OnTtsElevenLabsCommitted"/>
                        <TextBlock x:Uid="CapabilitiesPage_TtsElevenLabsHelp"
                                   Text="API key is encrypted at rest with Windows DPAPI. Leave blank to keep the previously saved value when you change other fields."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock x:Name="TtsStatusText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- MCP Server -->
            <Border x:Name="McpCard" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,8,0,0">
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="CapabilitiesPage_TextBlock_33" Text="Local MCP Server" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock x:Uid="CapabilitiesPage_TextBlock_34" Text="Expose capabilities via HTTP for CLI tools and local integrations."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                    <ToggleSwitch x:Name="McpToggle" Toggled="OnMcpToggled"/>
                    <StackPanel x:Name="McpDetailsPanel" Spacing="6" Visibility="Collapsed">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="CapabilitiesPage_TextBlock_44" Grid.Column="0" Text="Endpoint:" VerticalAlignment="Center"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock x:Name="McpEndpointText" Grid.Column="1" IsTextSelectionEnabled="True"
                                       VerticalAlignment="Center" FontFamily="Consolas"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Uid="CopyMcpTokenButton" x:Name="CopyMcpTokenButton" Content="Copy Token" Click="OnCopyMcpToken"/>
                            <Button x:Uid="CopyMcpUrlButton" x:Name="CopyMcpUrlButton" Content="Copy URL" Click="OnCopyMcpUrl"/>
                        </StackPanel>
                        <TextBlock x:Name="McpStatusText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Node status -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,8,0,0">
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="CapabilitiesPage_TextBlock_66" Text="Node Status" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse x:Name="NodeStatusDot" Width="10" Height="10"
                                 VerticalAlignment="Center" Fill="Gray"/>
                        <TextBlock x:Uid="NodeStatusText" x:Name="NodeStatusText" Text="Node mode disabled"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="NodeDetailsText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ═══ Advanced settings — deep-link to existing detail pages ═══ -->
            <!-- For users who want fine-grained control beyond the Security Level
                 + per-row toggles. Sandbox folder/network/clipboard policy lives
                 on the Sandbox page; exec-policy rules and OS permission status
                 live on the Permissions page. -->
            <Border x:Name="AdvancedSettingsCard"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,16,0,0"
                    AutomationProperties.AutomationId="AdvancedSettingsCard">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE713;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Advanced settings" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </StackPanel>
                    <TextBlock Text="The Security Level above covers most users. For fine-grained control, use these:"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <FontIcon Grid.Row="0" Grid.Column="0" Glyph="&#xE72E;" FontSize="14" VerticalAlignment="Center"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                            <TextBlock Text="Run Programs container (Sandbox)"/>
                            <TextBlock Text="Folders agents can reach, network egress, clipboard, timeout."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Row="0" Grid.Column="2" Content="Open" Click="OnOpenSandbox"
                                AutomationProperties.AutomationId="OpenSandboxButton"/>

                        <FontIcon Grid.Row="1" Grid.Column="0" Glyph="&#xE8D7;" FontSize="14" VerticalAlignment="Center"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                            <TextBlock Text="Permissions"/>
                            <TextBlock Text="Exec policy rules · gateway allowlist · Windows OS permission status."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Row="1" Grid.Column="2" Content="Open" Click="OnOpenPermissions"
                                AutomationProperties.AutomationId="OpenPermissionsButton"/>

                        <FontIcon Grid.Row="2" Grid.Column="0" Glyph="&#xE770;" FontSize="14" VerticalAlignment="Center"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2">
                            <TextBlock Text="🪟 Windows Privacy settings"/>
                            <TextBlock Text="OS-level camera, microphone, and screen capture permissions."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Row="2" Grid.Column="2" Content="Open" Click="OnOpenWindowsPrivacy"
                                AutomationProperties.AutomationId="OpenWindowsPrivacyButton"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
