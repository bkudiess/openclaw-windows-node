<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OpenClawTray.Pages.DebugPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:Microsoft.UI.Xaml.Controls"
      xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
      xmlns:helpers="using:OpenClawTray.Helpers">

    <!--
        Diagnostics page (route still "debug" for back-compat with command
        palette / deep links). Composition follows
        docs/design/surfaces/diagnostics-page.md (forthcoming) and the
        rules in docs/design/iconography.md and docs/design/tokens.md:
        every glyph goes through FluentIconCatalog, status colors come
        from SystemFill* tokens, and the page uses CommunityToolkit
        SettingsCard / SettingsExpander instead of hand-rolled rows.

        Three task-oriented sections + an in-page detail view for
        high-density diagnostic streams (event timeline / recent log).
        The detail view follows the same Visibility-swap pattern as
        ConnectionPage's AddGateway sub-view.
    -->

    <Page.Resources>
        <x:Double x:Key="DiagSettingsCardSpacing">4</x:Double>
        <Style x:Key="DiagSectionHeaderTextBlockStyle"
               BasedOn="{StaticResource BodyStrongTextBlockStyle}"
               TargetType="TextBlock">
            <Setter Property="Margin" Value="1,30,0,6"/>
        </Style>
    </Page.Resources>

    <Grid>

        <!-- Body host. MainView and DetailView are siblings; we swap
             Visibility to navigate without losing this Page's instance,
             matching ConnectionPage.AddGatewayPanel.

             The page title now lives INSIDE MainView's StackPanel
             (same column as the SettingsCards) — that's the
             WinUI Gallery / Permissions page pattern. Putting the
             title and the cards in one StackPanel guarantees they
             share the exact same MaxWidth=900 centered column and
             left-edge alignment, regardless of how narrow the title
             text is on its own. -->

            <!-- ─── MAIN VIEW ─────────────────────────────────────────── -->
            <ScrollViewer x:Name="MainView"
                          Padding="24,24,24,24"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollMode="Disabled">
                <StackPanel HorizontalAlignment="Center"
                            Width="900"
                            Spacing="{StaticResource DiagSettingsCardSpacing}">

                    <!-- Title block (in-stack, same column as cards). -->
                    <TextBlock x:Uid="DiagnosticsPage_Title"
                               Text="Diagnostics"
                               Style="{StaticResource TitleTextBlockStyle}"
                               Margin="0,0,0,2"/>
                    <TextBlock x:Uid="DiagnosticsPage_Subtitle"
                               Text="Inspect, export, and troubleshoot your OpenClaw installation."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,12"/>

                    <!-- Top status InfoBar. Both actions render as
                         HyperlinkButtons inside InfoBar.Content (matches
                         the Win11 Settings convention — see Settings →
                         System → Storage). Padding=0 strips button chrome
                         so they read as inline links flush with the
                         message text. -->
                    <controls:InfoBar x:Name="StatusInfoBar"
                                      IsOpen="True"
                                      IsClosable="False"
                                      Severity="Informational"
                                      Title="Status"
                                      Margin="0,0,0,12">
                        <controls:InfoBar.Content>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="20"
                                        Margin="0,4,0,8">
                                <HyperlinkButton x:Uid="DiagnosticsPage_OpenEventTimeline"
                                                 Content="View event timeline"
                                                 Click="OnShowEventTimeline"
                                                 Padding="0"
                                                 AutomationProperties.AutomationId="DiagnosticsViewEventTimeline"/>
                                <HyperlinkButton x:Uid="DiagnosticsPage_ManageOnConnection"
                                                 Content="Manage on Connection page"
                                                 Click="OnManageOnConnection"
                                                 Padding="0"/>
                            </StackPanel>
                        </controls:InfoBar.Content>
                    </controls:InfoBar>

                    <!-- Share diagnostics with support -->
                    <TextBlock x:Uid="DiagnosticsPage_Section_Share"
                               Text="Share diagnostics with support"
                               Style="{StaticResource DiagSectionHeaderTextBlockStyle}"/>

                    <toolkit:SettingsCard x:Uid="DiagnosticsPage_Card_Bundle"
                                          Header="Create diagnostics bundle"
                                          Description="Includes connection, gateway, ports, capabilities, log tail, and device summary. Preview before sharing."
                                          IsClickEnabled="True"
                                          Click="OnCreateDiagnosticsBundle">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="{x:Bind helpers:FluentIconCatalog.Briefcase, Mode=OneTime}"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                        </toolkit:SettingsCard.HeaderIcon>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="DiagnosticsPage_Card_OpenDiagnosticsFolder"
                                          Header="Open diagnostics folder"
                                          Description="Logs and structured diagnostics (.jsonl) live here."
                                          IsClickEnabled="True"
                                          Click="OnOpenDiagnosticsFolder">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="{x:Bind helpers:FluentIconCatalog.Folder, Mode=OneTime}"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                        </toolkit:SettingsCard.HeaderIcon>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsExpander x:Uid="DiagnosticsPage_Expander_SpecificCopies"
                                              Header="Copy specific diagnostic text"
                                              Description="Send just one piece of context.">
                        <toolkit:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="{x:Bind helpers:FluentIconCatalog.Copy, Mode=OneTime}"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                        </toolkit:SettingsExpander.HeaderIcon>
                        <toolkit:SettingsExpander.Items>
                            <toolkit:SettingsCard x:Uid="DiagnosticsPage_Card_CopySupport"
                                                  Header="Copy support context"
                                                  Description="Connection state, gateway URL, runtime, tunnel."
                                                  IsClickEnabled="True"
                                                  Click="OnCopySupportContext"/>
                            <toolkit:SettingsCard x:Uid="DiagnosticsPage_Card_CopyDebugBundle"
                                                  Header="Copy full debug bundle"
                                                  Description="Everything the preview dialog produces, no preview."
                                                  IsClickEnabled="True"
                                                  Click="OnCopyDebugBundle"/>
                            <toolkit:SettingsCard x:Uid="DiagnosticsPage_Card_CopyBrowserSetup"
                                                  Header="Copy browser setup guidance"
                                                  IsClickEnabled="True"
                                                  Click="OnCopyBrowserSetup"/>
                            <toolkit:SettingsCard x:Uid="DiagnosticsPage_Card_CopyPortDiagnostics"
                                                  Header="Copy port diagnostics"
                                                  IsClickEnabled="True"
                                                  Click="OnCopyPortDiagnostics"/>
                            <toolkit:SettingsCard x:Uid="DiagnosticsPage_Card_CopyCapabilityDiagnostics"
                                                  Header="Copy capability diagnostics"
                                                  IsClickEnabled="True"
                                                  Click="OnCopyCapabilityDiagnostics"/>
                        </toolkit:SettingsExpander.Items>
                    </toolkit:SettingsExpander>

                    <!-- Inspect local diagnostics -->
                    <TextBlock x:Uid="DiagnosticsPage_Section_Inspect"
                               Text="Inspect local diagnostics"
                               Style="{StaticResource DiagSectionHeaderTextBlockStyle}"/>

                    <toolkit:SettingsCard x:Uid="DiagnosticsPage_Card_EventTimeline"
                                          Header="Connection event timeline"
                                          Description="Live state-machine events, websocket frames, credential resolution, and pairing handshakes.">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="{x:Bind helpers:FluentIconCatalog.System, Mode=OneTime}"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                        </toolkit:SettingsCard.HeaderIcon>
                        <Button x:Uid="DiagnosticsPage_OpenEventTimelineButton"
                                Content="Open"
                                Click="OnShowEventTimeline"
                                AutomationProperties.AutomationId="DiagnosticsOpenEventTimeline"/>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="DiagnosticsPage_Card_RecentLog"
                                          Header="Recent log"
                                          Description="Last 200 lines of openclaw-tray.log, with severity coloring.">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="{x:Bind helpers:FluentIconCatalog.Document, Mode=OneTime}"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                        </toolkit:SettingsCard.HeaderIcon>
                        <Button x:Uid="DiagnosticsPage_OpenRecentLogButton"
                                Content="Open"
                                Click="OnShowRecentLog"
                                AutomationProperties.AutomationId="DiagnosticsOpenRecentLog"/>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsExpander x:Uid="DiagnosticsPage_Expander_Identity"
                                              Header="Device identity"
                                              Description="Local cryptographic identifiers for this device.">
                        <toolkit:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="{x:Bind helpers:FluentIconCatalog.Lock, Mode=OneTime}"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                        </toolkit:SettingsExpander.HeaderIcon>
                        <toolkit:SettingsExpander.Items>
                            <toolkit:SettingsCard x:Uid="DiagnosticsPage_Card_DeviceId"
                                                  Header="Device ID"
                                                  IsClickEnabled="True"
                                                  Click="OnCopyDeviceId">
                                <toolkit:SettingsCard.ActionIcon>
                                    <FontIcon Glyph="{x:Bind helpers:FluentIconCatalog.Copy, Mode=OneTime}"
                                              FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                                </toolkit:SettingsCard.ActionIcon>
                                <TextBlock x:Name="DeviceIdText"
                                           Text="—"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           IsTextSelectionEnabled="True"/>
                            </toolkit:SettingsCard>
                            <toolkit:SettingsCard x:Uid="DiagnosticsPage_Card_PublicKey"
                                                  Header="Public key"
                                                  IsClickEnabled="True"
                                                  Click="OnCopyPublicKey">
                                <toolkit:SettingsCard.ActionIcon>
                                    <FontIcon Glyph="{x:Bind helpers:FluentIconCatalog.Copy, Mode=OneTime}"
                                              FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                                </toolkit:SettingsCard.ActionIcon>
                                <TextBlock x:Name="PublicKeyText"
                                           Text="—"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           IsTextSelectionEnabled="True"
                                           TextWrapping="Wrap"
                                           MaxWidth="520"/>
                            </toolkit:SettingsCard>
                        </toolkit:SettingsExpander.Items>
                    </toolkit:SettingsExpander>

                    <!-- Developer tools -->
                    <TextBlock x:Uid="DiagnosticsPage_Section_Developer"
                               Text="Developer tools"
                               Style="{StaticResource DiagSectionHeaderTextBlockStyle}"/>

                    <controls:InfoBar IsOpen="True"
                                      IsClosable="False"
                                      Severity="Warning"
                                      x:Uid="DiagnosticsPage_DeveloperWarning"
                                      Title="For engineers"
                                      Message="These tools may change app behavior, restart the app, or open experimental UI."
                                      Margin="0,0,0,4"/>

                    <toolkit:SettingsExpander x:Uid="DiagnosticsPage_Expander_ChatOverrides"
                                              Header="Chat surface overrides"
                                              Description="Per-surface override of the chat UI. Resets when OpenClaw restarts.">
                        <toolkit:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="{x:Bind helpers:FluentIconCatalog.Chat, Mode=OneTime}"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                        </toolkit:SettingsExpander.HeaderIcon>
                        <toolkit:SettingsExpander.Items>
                            <toolkit:SettingsCard x:Uid="DiagnosticsPage_Card_HubChat"
                                                  Header="Hub chat tab">
                                <ComboBox x:Name="HubChatOverrideCombo"
                                          MinWidth="220"
                                          AutomationProperties.AutomationId="DebugPageHubChatOverride"
                                          SelectionChanged="OnHubChatOverrideChanged">
                                    <ComboBoxItem Content="No override" Tag="NoOverride"/>
                                    <ComboBoxItem Content="Force Gateway Chat UI" Tag="ForceLegacy"/>
                                    <ComboBoxItem Content="Force Companion Chat UI" Tag="ForceNative"/>
                                </ComboBox>
                            </toolkit:SettingsCard>
                            <toolkit:SettingsCard x:Uid="DiagnosticsPage_Card_TrayChat"
                                                  Header="Tray chat popup">
                                <ComboBox x:Name="TrayChatOverrideCombo"
                                          MinWidth="220"
                                          AutomationProperties.AutomationId="DebugPageTrayChatOverride"
                                          SelectionChanged="OnTrayChatOverrideChanged">
                                    <ComboBoxItem Content="No override" Tag="NoOverride"/>
                                    <ComboBoxItem Content="Force Gateway Chat UI" Tag="ForceLegacy"/>
                                    <ComboBoxItem Content="Force Companion Chat UI" Tag="ForceNative"/>
                                </ComboBox>
                            </toolkit:SettingsCard>
                        </toolkit:SettingsExpander.Items>
                    </toolkit:SettingsExpander>

                    <toolkit:SettingsCard x:Uid="DiagnosticsPage_Card_ChatExplorations"
                                          Header="Open chat explorations"
                                          Description="Engineering preview of chat bubble and tool-card rendering."
                                          IsClickEnabled="True"
                                          Click="OnOpenChatExplorations"
                                          AutomationProperties.AutomationId="DebugPageOpenChatExplorations">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="{x:Bind helpers:FluentIconCatalog.Develop, Mode=OneTime}"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                        </toolkit:SettingsCard.HeaderIcon>
                        <toolkit:SettingsCard.ActionIcon>
                            <FontIcon Glyph="{x:Bind helpers:FluentIconCatalog.OpenInBrowser, Mode=OneTime}"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                        </toolkit:SettingsCard.ActionIcon>
                    </toolkit:SettingsCard>

                    <!-- Reconfigure… — canonical action verb per naming.md
                         (action that walks the user back through the
                         onboarding wizard). Always followed by `…` because
                         it opens a wizard. -->
                    <toolkit:SettingsCard x:Uid="DiagnosticsPage_Card_Reconfigure"
                                          Header="Reconfigure…"
                                          Description="Reopens the OpenClaw onboarding wizard. You will be asked to confirm.">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="{x:Bind helpers:FluentIconCatalog.Setup, Mode=OneTime}"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                        </toolkit:SettingsCard.HeaderIcon>
                        <Button x:Uid="DiagnosticsPage_ReconfigureButton"
                                Content="Reconfigure…"
                                Click="OnRelaunchOnboarding"/>
                    </toolkit:SettingsCard>

                </StackPanel>
            </ScrollViewer>

            <!-- ─── DETAIL VIEW ───────────────────────────────────────── -->
            <!-- Hidden by default. Hosts two modes (timeline / log) that
                 share the same RichTextBlock body so coloring is uniform.
                 The body uses Border + RichTextBlock (not a SettingsCard)
                 because it's a content reader, not a settings row.

                 Outer Grid carries the 24,12,24,24 page padding (same as
                 MainView's ScrollViewer); inner Grid caps content at
                 MaxWidth=900 + HorizontalAlignment=Stretch so the
                 detail-view width matches MainView's StackPanel exactly. -->
            <Grid x:Name="DetailView"
                  Visibility="Collapsed"
                  Padding="24,12,24,24">
                <Grid Width="900"
                      HorizontalAlignment="Center"
                      RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="2">
                    <HyperlinkButton x:Name="DetailBackButton"
                                     Padding="0"
                                     Click="OnBackToMain"
                                     AutomationProperties.AutomationId="DiagnosticsDetailBack">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="{x:Bind helpers:FluentIconCatalog.Back, Mode=OneTime}"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="11"
                                      VerticalAlignment="Center"/>
                            <TextBlock x:Uid="DiagnosticsPage_DetailBack"
                                       Text="Back to Diagnostics"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </HyperlinkButton>
                    <TextBlock x:Name="DetailTitle"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               AutomationProperties.HeadingLevel="Level1"/>
                    <TextBlock x:Name="DetailCaption"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button x:Name="DetailRefreshButton"
                            Click="OnDetailRefresh"
                            ToolTipService.ToolTip="Refresh">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="{x:Bind helpers:FluentIconCatalog.Refresh, Mode=OneTime}"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="12"/>
                            <TextBlock Text="Refresh"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="DetailCopyButton"
                            Click="OnDetailCopy"
                            ToolTipService.ToolTip="Copy to clipboard">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="{x:Bind helpers:FluentIconCatalog.Copy, Mode=OneTime}"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="12"/>
                            <TextBlock Text="Copy"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="DetailClearButton"
                            Click="OnDetailClear"
                            ToolTipService.ToolTip="Clear timeline buffer">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="{x:Bind helpers:FluentIconCatalog.Clear, Mode=OneTime}"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="12"/>
                            <TextBlock Text="Clear"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="DetailOpenFileButton"
                            Click="OnDetailOpenFile"
                            ToolTipService.ToolTip="Open log file in default editor"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="{x:Bind helpers:FluentIconCatalog.OpenInBrowser, Mode=OneTime}"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="12"/>
                            <TextBlock Text="Open file"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Row="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource OverlayCornerRadius}"
                        Padding="10">
                    <ScrollViewer x:Name="DetailScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <RichTextBlock x:Name="DetailRichText"
                                       FontFamily="Consolas"
                                       FontSize="11.5"
                                       IsTextSelectionEnabled="True"
                                       TextWrapping="Wrap"
                                       AutomationProperties.Name="Diagnostics detail content"/>
                    </ScrollViewer>
                </Border>
                </Grid>
            </Grid>

    </Grid>
</Page>
