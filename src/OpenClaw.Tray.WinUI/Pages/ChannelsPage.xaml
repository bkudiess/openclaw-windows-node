<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.ChannelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:OpenClawTray.Helpers">

    <!--
        ╔════════════════════════════════════════════════════════════════════╗
        ║  Channels page — single-column Expander layout                     ║
        ║                                                                    ║
        ║  Channels are surfaced as a vertical stack of Expander cards       ║
        ║  grouped into Configured / Available, matching the existing        ║
        ║  ConnectionPage Expander pattern (no inner sidebar — the HubWindow ║
        ║  nav rail already provides outer navigation).                      ║
        ║                                                                    ║
        ║  Content within each card mirrors what the macOS Channels          ║
        ║  Settings shows for the same channel.                              ║
        ║                                                                    ║
        ║  Data source: gateway channels.status (canonical wire method;      ║
        ║  see OpenClawGatewayClient.GetChannelsStatusAsync).                ║
        ╚════════════════════════════════════════════════════════════════════╝
    -->

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid HorizontalAlignment="Stretch">
            <StackPanel Padding="24" Spacing="16"
                        HorizontalAlignment="Stretch" MaxWidth="900">

                <!-- ═════════════════════════════════════════════════════════
                     PAGE HEADER — title + last-check meta + Refresh
                     ═════════════════════════════════════════════════════════ -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="ChannelsPage_Title" Text="Channels"
                                   Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock x:Name="MetaText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text=""/>
                    </StackPanel>
                    <Button Grid.Column="1" x:Name="RefreshButton" Click="OnRefreshAll"
                            VerticalAlignment="Center"
                            AutomationProperties.AutomationId="ChannelsRefreshAll"
                            AutomationProperties.Name="Refresh all channels">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                            <TextBlock x:Uid="ChannelsPage_Refresh" Text="Refresh"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Single canonical "what is this page / where do I go for help"
                     orienting line. Channels are gateway-side state; the form
                     below writes to the gateway's config. Docs link is THE
                     authoritative answer to "how do I set this up". -->
                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="14,10">
                    <StackPanel Spacing="6">
                        <TextBlock x:Uid="ChannelsPage_Intro"
                                   Text="Channels are configured on your gateway. To add one, expand it below and fill in its credentials. The form saves directly to your gateway's config."
                                   TextWrapping="Wrap"
                                   FontSize="13"/>
                        <HyperlinkButton x:Uid="ChannelsPage_DocsLink"
                                         Content="Read the channels guide →"
                                         NavigateUri="https://docs.openclaw.ai/channels"
                                         Padding="0"
                                         AutomationProperties.Name="Open the OpenClaw channels documentation"/>
                    </StackPanel>
                </Border>

                <!-- "Not connected to gateway" InfoBar -->
                <InfoBar x:Uid="ChannelsPage_NotConnected"
                         x:Name="NotConnectedBar"
                         Title="Not connected"
                         Message="Connect to a gateway to manage channels."
                         Severity="Error" IsOpen="False" IsClosable="False"/>

                <!-- Generic error InfoBar (channels.status failed, etc.) -->
                <InfoBar x:Uid="ChannelsPage_ErrorBar"
                         x:Name="ErrorBar"
                         Severity="Warning" IsOpen="False" IsClosable="True"/>

                <!-- Shown when the gateway is connected but its channels.status
                     response was empty. The list below is then a preview of
                     common channels the user can attempt to configure. -->
                <InfoBar x:Uid="ChannelsPage_GatewayMissingChannelsBar"
                         x:Name="GatewayMissingChannelsBar"
                         Severity="Informational"
                         IsOpen="False"
                         IsClosable="False"
                         Title="Your gateway didn't list any channels"
                         Message="Showing common channel types as a preview. Some may not be supported by your gateway — try one, and the error message will tell you if so."/>

                <!-- ═════════════════════════════════════════════════════════
                     CONFIGURED GROUP — channels with active state
                     ═════════════════════════════════════════════════════════ -->
                <StackPanel x:Name="ConfiguredSection" Spacing="4" Visibility="Collapsed">
                    <TextBlock x:Uid="ChannelsPage_ConfiguredHeader" Text="CONFIGURED"
                               FontSize="11" FontWeight="SemiBold"
                               CharacterSpacing="80"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Margin="4,8,4,4"/>
                    <StackPanel x:Name="ConfiguredList" Spacing="8"/>
                </StackPanel>

                <!-- ═════════════════════════════════════════════════════════
                     AVAILABLE GROUP — channels not yet configured
                     ═════════════════════════════════════════════════════════ -->
                <StackPanel x:Name="AvailableSection" Spacing="4" Visibility="Collapsed">
                    <TextBlock x:Uid="ChannelsPage_AvailableHeader" Text="AVAILABLE"
                               FontSize="11" FontWeight="SemiBold"
                               CharacterSpacing="80"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Margin="4,8,4,4"/>
                    <StackPanel x:Name="AvailableList" Spacing="8"/>
                </StackPanel>

                <!-- Empty state — only visible when there are zero channels at all -->
                <StackPanel x:Name="EmptyState" Spacing="8" HorizontalAlignment="Center" Margin="0,32,0,0"
                            Visibility="Collapsed">
                    <FontIcon Glyph="{x:Bind helpers:FluentIconCatalog.Channels, Mode=OneTime}"
                              FontSize="40"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                              HorizontalAlignment="Center"/>
                    <TextBlock x:Uid="ChannelsPage_EmptyTitle"
                               Text="No channels available"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Uid="ChannelsPage_EmptySubtitle"
                               Text="The gateway didn't report any channels. Install channel plugins on the gateway and refresh."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap" MaxWidth="380"/>
                </StackPanel>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
