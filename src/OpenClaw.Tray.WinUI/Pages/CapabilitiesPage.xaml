<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.CapabilitiesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="36,28" Spacing="14" HorizontalAlignment="Stretch" MaxWidth="980">

            <!-- ════ Title ════ -->
            <TextBlock x:Uid="CapabilitiesPage_TextBlock_10" Text="Security" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock x:Name="HostnameText"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock x:Uid="CapabilitiesPage_TextBlock_15"
                       Text="An agent connected through your gateway can use the capabilities below. Choose how protected this PC should be and what each agent can access."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap" MaxWidth="680" Margin="0,0,0,4"/>

            <!-- ════ Hero status + Security level (Sandbox-style hero) ════ -->
            <Border x:Name="SecurityLevelCard"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20"
                    AutomationProperties.AutomationId="SecurityLevelCard">
                <StackPanel Spacing="16">
                    <!-- Hero row: big icon · big title · subtext · status pill -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" x:Name="HeroIcon"
                                  Glyph="&#xE73E;" FontSize="32"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                  VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock x:Name="HeroTitle" Text="Recommended"
                                       Style="{StaticResource TitleTextBlockStyle}"/>
                            <TextBlock x:Name="HeroSubtext"
                                       Text="Programs run inside a Windows container. Camera and screen require approval. MCP server is off."
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Border x:Name="LevelBadge" Grid.Column="2"
                                CornerRadius="12" Padding="12,4"
                                Background="{ThemeResource AccentFillColorTertiaryBrush}"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="LevelBadgeText" Text="Recommended" FontSize="12"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        </Border>
                    </Grid>

                    <!-- Preset buttons (Sandbox-style — bigger, with icon + title + description) -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Choose a security level"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="Sets safe defaults for everything below. You can override anything afterward — changes show as 'Custom'."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                        <Grid ColumnSpacing="12" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="LockedDownButton" Grid.Column="0"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                    VerticalAlignment="Stretch" VerticalContentAlignment="Top"
                                    Padding="20,16" MinHeight="130" CornerRadius="8"
                                    Click="OnLevelLockedDownClick"
                                    AutomationProperties.AutomationId="LockedDownButton">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE72E;" FontSize="18"/>
                                        <TextBlock Text="Locked down" FontSize="16" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock Text="No programs. No network. No camera or screen without asking."
                                               TextWrapping="Wrap" FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="RecommendedButton" Grid.Column="1"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                    VerticalAlignment="Stretch" VerticalContentAlignment="Top"
                                    Padding="20,16" MinHeight="130" CornerRadius="8"
                                    Click="OnLevelRecommendedClick"
                                    AutomationProperties.AutomationId="RecommendedButton">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE73E;" FontSize="18"/>
                                        <TextBlock Text="Recommended" FontSize="16" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock Text="Programs run in a container. Camera and screen ask first. Internet is blocked from program code."
                                               TextWrapping="Wrap" FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="TrustedButton" Grid.Column="2"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                    VerticalAlignment="Stretch" VerticalContentAlignment="Top"
                                    Padding="20,16" MinHeight="130" CornerRadius="8"
                                    Click="OnLevelTrustedClick"
                                    AutomationProperties.AutomationId="TrustedButton">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE930;" FontSize="18"/>
                                        <TextBlock Text="Trusted (developer)" FontSize="16" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock Text="Programs run directly. Camera and screen pre-approved. Internet allowed. Requires confirmation."
                                               TextWrapping="Wrap" FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="DriftPanel" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                        <FontIcon Glyph="&#xE946;" FontSize="14"
                                  Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                  VerticalAlignment="Center"/>
                        <TextBlock x:Name="DriftText" VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <HyperlinkButton x:Name="ResetLevelButton" Content="Reset to base level"
                                         Click="OnResetLevelClick" Padding="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Node mode moved to Connection page (it's a connectivity concern, not a security level). -->

            <!-- ════════ ACTIONS section ════════ -->
            <TextBlock Text="Actions"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,12,0,0"/>
            <TextBlock Text="Things agents can do on this PC. Higher risk because they can change state or reach the network."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"/>

            <!-- Run programs — comprehensive inline detail -->
            <Border x:Name="RunProgramsCard"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="14">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE756;" FontSize="20"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Run programs" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Name="RunProgramsSummary"
                                       Text="Lets agents run shell commands, scripts, and programs on this PC."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="RunProgramsToggle" Grid.Column="2" VerticalAlignment="Center"
                                      OnContent="" OffContent="" Toggled="OnRunProgramsToggled"
                                      AutomationProperties.AutomationId="RunProgramsToggle"/>
                    </Grid>

                    <InfoBar x:Name="MxcUnavailableBar" IsOpen="False" IsClosable="False"
                             Severity="Warning"
                             Title="Container unavailable"
                             Message="Container-based execution isn't supported on this PC. Switch to 'Direct' below to allow commands to run (less safe), or update Windows to add container support."/>

                    <StackPanel x:Name="RunProgramsDetail" Spacing="12" Visibility="Collapsed">

                        <!-- How they run — visible, not collapsed (high-importance choice) -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="How programs run" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <RadioButton x:Name="RunInContainerRadio"
                                         GroupName="RunMode"
                                         Content="In a container (recommended) — programs run with only the access you grant below"
                                         Checked="OnRunInContainerChecked"/>
                            <RadioButton x:Name="RunDirectRadio"
                                         GroupName="RunMode"
                                         Content="Direct — programs have your full Windows access. Requires confirmation."
                                         Checked="OnRunDirectChecked"/>
                        </StackPanel>

                        <!-- Files — collapsible -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="False">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Files" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Name="FilesExpanderSummary"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Spacing="8" Padding="0,4">
                                <TextBlock Text="By default, agents only see a temporary workspace folder. Grant access to your user folders below."
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                                <Grid ColumnSpacing="8" RowSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Documents" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="DocsAccessCombo"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnDocsAccessChanged">
                                        <ComboBoxItem Content="Blocked" Tag="None"/>
                                        <ComboBoxItem Content="Read only" Tag="ReadOnly"/>
                                        <ComboBoxItem Content="Read and write" Tag="ReadWrite"/>
                                    </ComboBox>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Downloads" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="DownloadsAccessCombo"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnDownloadsAccessChanged">
                                        <ComboBoxItem Content="Blocked" Tag="None"/>
                                        <ComboBoxItem Content="Read only" Tag="ReadOnly"/>
                                        <ComboBoxItem Content="Read and write" Tag="ReadWrite"/>
                                    </ComboBox>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Desktop" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="DesktopAccessCombo"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnDesktopAccessChanged">
                                        <ComboBoxItem Content="Blocked" Tag="None"/>
                                        <ComboBoxItem Content="Read only" Tag="ReadOnly"/>
                                        <ComboBoxItem Content="Read and write" Tag="ReadWrite"/>
                                    </ComboBox>
                                </Grid>
                                <TextBlock x:Name="CustomFolderSummary" Margin="0,4,0,0"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <HyperlinkButton Content="Manage custom folders"
                                                 Click="OnManageCustomFolders" Padding="0"/>
                            </StackPanel>
                        </Expander>

                        <!-- Network — collapsible -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="False">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE839;" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Network" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Name="NetworkExpanderSummary"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Spacing="6" Padding="0,4">
                                <ToggleSwitch x:Name="NetworkToggle"
                                              Header="Allow internet from program code"
                                              OffContent="Off — programs can't reach the internet"
                                              OnContent="On — programs can reach public internet endpoints"
                                              Toggled="OnNetworkToggled"/>
                                <TextBlock Text="When file or clipboard read access is on, programs that reach the internet could send that data outside this PC."
                                           Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Expander>

                        <!-- Clipboard — collapsible -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="False">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE77F;" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Clipboard" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Name="ClipboardExpanderSummary"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Spacing="6" Padding="0,4">
                                <TextBlock Text="Your clipboard often contains passwords, tokens, and private text."
                                           Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <RadioButton x:Name="ClipNoneRadio" Content="None (recommended)" GroupName="Clipboard" Checked="OnClipboardChanged" Tag="None"/>
                                <RadioButton x:Name="ClipReadRadio" Content="Read only — agent can see what you copied" GroupName="Clipboard" Checked="OnClipboardChanged" Tag="Read"/>
                                <RadioButton x:Name="ClipWriteRadio" Content="Write only — agent can replace your clipboard" GroupName="Clipboard" Checked="OnClipboardChanged" Tag="Write"/>
                                <RadioButton x:Name="ClipBothRadio" Content="Read and write" GroupName="Clipboard" Checked="OnClipboardChanged" Tag="Both"/>
                            </StackPanel>
                        </Expander>

                        <!-- Limits — collapsible -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="False">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE916;" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Resource limits" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Name="LimitsExpanderSummary"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Spacing="8" Padding="0,4">
                                <StackPanel Spacing="2">
                                    <TextBlock x:Name="TimeoutLabel" Text="Command timeout: 30 seconds"/>
                                    <Slider x:Name="TimeoutSlider" Minimum="5" Maximum="300" StepFrequency="5"
                                            Value="30" SmallChange="5" LargeChange="15"
                                            ValueChanged="OnTimeoutChanged"/>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Maximum captured output"/>
                                    <ComboBox x:Name="MaxOutputCombo" HorizontalAlignment="Stretch"
                                              SelectionChanged="OnMaxOutputChanged">
                                        <ComboBoxItem Content="1 MB" Tag="1048576"/>
                                        <ComboBoxItem Content="4 MB (default)" Tag="4194304"/>
                                        <ComboBoxItem Content="16 MB" Tag="16777216"/>
                                        <ComboBoxItem Content="64 MB" Tag="67108864"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <!-- Approval rules — collapsible -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="False">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE9CE;" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Approval rules" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Name="ApprovalExpanderSummary"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Spacing="6" Padding="0,4">
                                <TextBlock Text="What happens when an agent tries to run a command that doesn't match any rule below:"
                                           Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <ComboBox x:Name="ExecDefaultActionCombo" Width="240"
                                          SelectionChanged="OnExecDefaultActionChanged">
                                    <ComboBoxItem Content="Deny — block unknown commands" Tag="deny"/>
                                    <ComboBoxItem Content="Allow — run unknown commands" Tag="allow"/>
                                    <ComboBoxItem Content="Ask — prompt for each unknown command" Tag="ask"/>
                                </ComboBox>
                                <TextBlock Text="Rules (evaluated top to bottom; first match wins):"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Margin="0,4,0,0"/>
                                <ListView x:Name="ExecRulesList" SelectionMode="None" MaxHeight="280">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="8,6" ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Pattern}" FontFamily="Consolas" VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" CornerRadius="4" Padding="6,2" HorizontalAlignment="Center"
                                                        Background="{Binding ActionBrush}">
                                                    <TextBlock Text="{Binding Action}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                                </Border>
                                                <Button Grid.Column="2" Click="OnRemoveExecRule" Tag="{Binding Index}"
                                                        Padding="4,2" MinWidth="0" Background="Transparent"
                                                        ToolTipService.ToolTip="Remove rule">
                                                    <FontIcon Glyph="&#xE894;" FontSize="12"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBox x:Name="NewExecRulePattern" PlaceholderText="Command pattern (for example: echo *)" Width="320"/>
                                    <ComboBox x:Name="NewExecRuleAction" Width="110" SelectedIndex="0">
                                        <ComboBoxItem Content="allow"/>
                                        <ComboBoxItem Content="deny"/>
                                    </ComboBox>
                                    <Button Content="Add rule" Click="OnAddExecRule"/>
                                </StackPanel>
                                <Button x:Name="SaveExecPolicyButton" Content="Save rules" Click="OnSaveExecPolicy"
                                        Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Browser control -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE774;" FontSize="20"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Browser control" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="Lets agents open URLs, fill forms, and click links in a browser tab on this PC."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <ToggleSwitch x:Name="BrowserToggle" Grid.Column="2" VerticalAlignment="Center"
                                  OnContent="" OffContent="" Toggled="OnBrowserToggled"/>
                </Grid>
            </Border>

            <!-- Canvas -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE737;" FontSize="20"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Canvas" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="Lets agents show formatted content (text, HTML, A2UI) in a small overlay on this PC."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <ToggleSwitch x:Name="CanvasToggle" Grid.Column="2" VerticalAlignment="Center"
                                  OnContent="" OffContent="" Toggled="OnCanvasToggled"/>
                </Grid>
            </Border>

            <!-- Local MCP server -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE968;" FontSize="20"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Local MCP server" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Exposes this PC's capabilities to local tools (Claude Desktop, Cursor, and similar) over a token-protected HTTP endpoint."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="McpToggle" Grid.Column="2" VerticalAlignment="Center"
                                      OnContent="" OffContent="" Toggled="OnMcpToggled"/>
                    </Grid>
                    <StackPanel x:Name="McpDetailPanel" Spacing="8" Visibility="Collapsed">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Endpoint" VerticalAlignment="Center"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="McpEndpointText" IsTextSelectionEnabled="True"
                                       VerticalAlignment="Center" FontFamily="Consolas"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                            <Button Grid.Column="2" Content="Copy URL" Click="OnCopyMcpUrl"/>
                        </Grid>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Token" VerticalAlignment="Center"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="McpTokenText" Text="•••••••••••••"
                                       VerticalAlignment="Center" FontFamily="Consolas"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                            <Button Grid.Column="2" Content="Reveal" Click="OnRevealMcpToken"/>
                            <Button Grid.Column="3" Content="Copy" Click="OnCopyMcpToken"/>
                        </Grid>
                        <TextBlock x:Name="McpStatusText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ════════ CAPABILITIES section ════════ -->
            <TextBlock Text="Capabilities"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,12,0,0"/>
            <TextBlock Text="Device-level access — what agents can see, hear, and locate. Each also requires the matching Windows permission."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"/>

            <!-- Camera -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE722;" FontSize="20"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Camera" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Lets agents capture photos and short clips from your webcam."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="CameraToggle" Grid.Column="2" VerticalAlignment="Center"
                                      OnContent="" OffContent="" Toggled="OnCameraToggled"/>
                    </Grid>
                    <StackPanel x:Name="CameraDetailPanel" Spacing="6" Visibility="Collapsed" Margin="32,0,0,0">
                        <CheckBox x:Name="CameraAlwaysAllowCb" Content="Always allow — don't ask before each use"
                                  Checked="OnCameraAlwaysAllowChanged" Unchecked="OnCameraAlwaysAllowChanged"/>
                        <HyperlinkButton Content="Open Windows camera settings"
                                         Click="OnOpenWindowsCamera" Padding="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Screen capture -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE7F4;" FontSize="20"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Screen capture" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Lets agents take screenshots and record video of your screen."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="ScreenToggle" Grid.Column="2" VerticalAlignment="Center"
                                      OnContent="" OffContent="" Toggled="OnScreenToggled"/>
                    </Grid>
                    <StackPanel x:Name="ScreenDetailPanel" Spacing="6" Visibility="Collapsed" Margin="32,0,0,0">
                        <CheckBox x:Name="ScreenAlwaysAllowCb" Content="Always allow — don't ask before each recording"
                                  Checked="OnScreenAlwaysAllowChanged" Unchecked="OnScreenAlwaysAllowChanged"/>
                        <HyperlinkButton Content="Open Windows screen recording settings"
                                         Click="OnOpenWindowsScreen" Padding="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Microphone -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE720;" FontSize="20"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock x:Uid="CapabilitiesPage_SttCardHeader" Text="Microphone" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Uid="CapabilitiesPage_SttCardDescription"
                                       Text="Transcribes microphone audio to text locally on this PC. The speech model downloads once on first use; audio doesn't leave this PC."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="SttToggle" Grid.Column="2" VerticalAlignment="Center"
                                      OnContent="" OffContent="" Toggled="OnSttToggled"/>
                    </Grid>
                    <StackPanel x:Name="SttDetailPanel" Spacing="6" Visibility="Collapsed" Margin="32,0,0,0">
                        <TextBlock x:Name="SttEngineHint"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                        <HyperlinkButton x:Uid="CapabilitiesPage_SttMoreSettingsLink"
                                         Content="More voice settings"
                                         Click="OnSttMoreSettingsClick" Padding="0"/>
                        <HyperlinkButton Content="Open Windows microphone settings"
                                         Click="OnOpenWindowsMic" Padding="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Location -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE81D;" FontSize="20"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Location" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Lets agents read your approximate location from Windows."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="LocationToggle" Grid.Column="2" VerticalAlignment="Center"
                                      OnContent="" OffContent="" Toggled="OnLocationToggled"/>
                    </Grid>
                    <StackPanel x:Name="LocationDetailPanel" Spacing="6" Visibility="Collapsed" Margin="32,0,0,0">
                        <HyperlinkButton Content="Open Windows location settings"
                                         Click="OnOpenWindowsLocation" Padding="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ════════ AUDIO OUTPUT section ════════ -->
            <TextBlock Text="Audio output"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,12,0,0"/>

            <!-- Text to speech -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE767;" FontSize="20"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock x:Uid="CapabilitiesPage_TtsCardHeader" Text="Text to speech" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Uid="CapabilitiesPage_TtsCardDescription"
                                       Text="Lets agents speak through your speakers. Choose a provider below."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="TtsToggle" Grid.Column="2" VerticalAlignment="Center"
                                      OnContent="" OffContent="" Toggled="OnTtsToggled"/>
                    </Grid>
                    <StackPanel x:Name="TtsDetailPanel" Spacing="8" Visibility="Collapsed" Margin="32,0,0,0">
                        <ComboBox x:Name="TtsProviderCombo" x:Uid="CapabilitiesPage_TtsProviderComboBox" Header="Provider"
                                  SelectionChanged="OnTtsProviderChanged">
                            <ComboBoxItem x:Uid="CapabilitiesPage_TtsProviderPiper" Content="Piper — local, recommended" Tag="piper"/>
                            <ComboBoxItem x:Uid="CapabilitiesPage_TtsProviderWindows" Content="Windows — built-in speech" Tag="windows"/>
                            <ComboBoxItem x:Uid="CapabilitiesPage_TtsProviderElevenLabs" Content="ElevenLabs — cloud" Tag="elevenlabs"/>
                        </ComboBox>
                        <StackPanel x:Name="TtsElevenLabsPanel" Spacing="6" Visibility="Collapsed">
                            <PasswordBox x:Name="TtsElevenLabsKey" x:Uid="CapabilitiesPage_TtsElevenLabsApiKey" Header="ElevenLabs API key"
                                         LostFocus="OnTtsElevenLabsCommitted"/>
                            <TextBox x:Name="TtsElevenLabsVoice" x:Uid="CapabilitiesPage_TtsElevenLabsVoiceId" Header="Voice ID"
                                     LostFocus="OnTtsElevenLabsCommitted"/>
                            <TextBox x:Name="TtsElevenLabsModelBox" x:Uid="CapabilitiesPage_TtsElevenLabsModel" Header="Model"
                                     PlaceholderText="eleven_multilingual_v2"
                                     LostFocus="OnTtsElevenLabsCommitted"/>
                            <TextBlock x:Uid="CapabilitiesPage_TtsElevenLabsHelp"
                                       Text="The API key is encrypted at rest with Windows DPAPI."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock x:Name="TtsStatusText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ════════ GATEWAY ════════ -->
            <TextBlock Text="From the gateway"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,12,0,0"/>
            <TextBlock Text="Read-only. These are the commands the connected gateway is willing to forward to this PC. Edit them on the gateway side."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"/>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="GatewayAllowlistEmpty"
                               Text="No allowed commands available. Connect to a gateway first."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <ItemsRepeater x:Name="GatewayAllowlistRepeater">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="4"/>
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </StackPanel>
            </Border>

            <!-- Node status -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,12,0,0">
                <StackPanel Spacing="6">
                    <TextBlock Text="Node status" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse x:Name="NodeStatusDot" Width="10" Height="10"
                                 VerticalAlignment="Center" Fill="Gray"/>
                        <TextBlock x:Name="NodeStatusText" Text="Node mode is off" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="NodeDetailsText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
