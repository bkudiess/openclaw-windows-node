<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.CapabilitiesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Unloaded="OnPageUnloaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,16" Spacing="12" HorizontalAlignment="Stretch" MaxWidth="980">

            <!-- ════ Title ════ -->
            <TextBlock x:Uid="CapabilitiesPage_TextBlock_10" Text="Privacy &amp; security" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock x:Uid="CapabilitiesPage_TextBlock_15"
                       Text="Choose how protected this PC is, and what connected agents can access."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap" Margin="0,0,0,8"/>

            <!-- ════ Quick setup — preset chooser wrapped in a subtle container
                 so users immediately see "this controls everything below". -->
            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="12"
                    Padding="20" Margin="0,4,0,8">
                <StackPanel Spacing="12">

                    <StackPanel Spacing="2">
                        <TextBlock Text="Quick setup"
                                   Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="Pick a level — this sets every option below."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Preset buttons. Selection indicator is an overlay Border above each
                         button so the default Fluent hover/pressed visual states don't override
                         the accent. -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Button x:Name="LockedDownButton"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                    VerticalAlignment="Stretch" VerticalContentAlignment="Top"
                                    Padding="20,18" MinHeight="130" CornerRadius="8"
                                    Click="OnLevelLockedDownClick"
                                    AutomationProperties.AutomationId="LockedDownButton">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <TextBlock Text="🔒" FontSize="18" VerticalAlignment="Center"/>
                                        <TextBlock Text="Locked down" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="No programs. No internet. Camera and screen ask before each use."
                                               TextWrapping="Wrap" FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Button>
                            <Border x:Name="LockedDownSelectedOverlay"
                                    CornerRadius="8"
                                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                    BorderThickness="2"
                                    IsHitTestVisible="False"
                                    Visibility="Collapsed"/>
                        </Grid>

                        <Grid Grid.Column="1">
                            <Button x:Name="RecommendedButton"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                    VerticalAlignment="Stretch" VerticalContentAlignment="Top"
                                    Padding="20,18" MinHeight="130" CornerRadius="8"
                                    Click="OnLevelRecommendedClick"
                                    AutomationProperties.AutomationId="RecommendedButton">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <TextBlock Text="🛡️" FontSize="18" VerticalAlignment="Center"/>
                                        <TextBlock Text="Recommended" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="Programs run in a container. Camera and screen ask first. No internet from programs."
                                               TextWrapping="Wrap" FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Button>
                            <Border x:Name="RecommendedSelectedOverlay"
                                    CornerRadius="8"
                                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                    BorderThickness="2"
                                    IsHitTestVisible="False"
                                    Visibility="Collapsed"/>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Button x:Name="TrustedButton"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                    VerticalAlignment="Stretch" VerticalContentAlignment="Top"
                                    Padding="20,18" MinHeight="130" CornerRadius="8"
                                    Click="OnLevelTrustedClick"
                                    AutomationProperties.AutomationId="TrustedButton">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <TextBlock Text="⚠️" FontSize="18" VerticalAlignment="Center"/>
                                        <TextBlock Text="Unprotected" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="Programs run with your full Windows access. Camera and screen never ask. Use only if you trust every connected agent."
                                               TextWrapping="Wrap" FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Button>
                            <Border x:Name="TrustedSelectedOverlay"
                                    CornerRadius="8"
                                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                    BorderThickness="2"
                                    IsHitTestVisible="False"
                                    Visibility="Collapsed"/>
                        </Grid>
                    </Grid>

                    <!-- Drift indicator — only when settings differ from the active level -->
                    <StackPanel x:Name="DriftPanel" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                        <FontIcon Glyph="&#xE946;" FontSize="14"
                                  Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                  VerticalAlignment="Center"/>
                        <TextBlock x:Name="DriftText" VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <HyperlinkButton x:Name="ResetLevelButton" Content="Reset to base level"
                                         Click="OnResetLevelClick" Padding="0"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ════════ ACTIONS section ════════ -->
            <TextBlock Text="Actions"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,16,0,0"/>
            <TextBlock Text="Things agents can do on this PC. Higher risk because they can change state or reach the network."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"/>

            <!-- Run programs — comprehensive inline detail -->
            <Border x:Name="RunProgramsCard"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="14">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" HorizontalAlignment="Center" Glyph="&#xE756;" FontSize="20"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Run programs" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Name="RunProgramsSummary"
                                       Text="Lets agents run shell commands, scripts, and programs on this PC."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="RunProgramsToggle" Grid.Column="2" VerticalAlignment="Center"
                                      OnContent="" OffContent="" MinWidth="0" Toggled="OnRunProgramsToggled"
                                      AutomationProperties.AutomationId="RunProgramsToggle"/>
                    </Grid>

                    <InfoBar x:Name="MxcUnavailableBar" IsOpen="False" IsClosable="False"
                             Severity="Warning"
                             Title="Container unavailable"
                             Message="Container-based execution isn't supported on this PC. Switch to 'Direct' below to allow commands to run (less safe), or update Windows to add container support."/>

                    <StackPanel x:Name="RunProgramsDetail" Spacing="12">

                        <!-- How programs run — prominent two-card chooser (mirrors the
                             preset chooser at the top of the page; this is a major decision
                             that gates every container setting below it). -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="How programs run" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">
                                    <Button x:Name="InContainerButton"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                            VerticalAlignment="Stretch" VerticalContentAlignment="Top"
                                            Padding="16,14" MinHeight="100" CornerRadius="8"
                                            Click="OnRunInContainerClick"
                                            AutomationProperties.AutomationId="InContainerButton">
                                        <StackPanel Spacing="6">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <TextBlock Text="🛡️" FontSize="16" VerticalAlignment="Center"/>
                                                <TextBlock Text="In a container" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="Programs run with only the access you grant below. Recommended."
                                                       TextWrapping="Wrap" FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Button>
                                    <Border x:Name="InContainerSelectedOverlay"
                                            CornerRadius="8"
                                            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                            BorderThickness="2"
                                            IsHitTestVisible="False"
                                            Visibility="Collapsed"/>
                                </Grid>

                                <Grid Grid.Column="1">
                                    <Button x:Name="DirectButton"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                            VerticalAlignment="Stretch" VerticalContentAlignment="Top"
                                            Padding="16,14" MinHeight="100" CornerRadius="8"
                                            Click="OnRunDirectClick"
                                            AutomationProperties.AutomationId="DirectButton">
                                        <StackPanel Spacing="6">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <TextBlock Text="⚠️" FontSize="16" VerticalAlignment="Center"/>
                                                <TextBlock Text="Directly" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="Programs have your full Windows access. No file, network, or clipboard limits below apply."
                                                       TextWrapping="Wrap" FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Button>
                                    <Border x:Name="DirectSelectedOverlay"
                                            CornerRadius="8"
                                            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                            BorderThickness="2"
                                            IsHitTestVisible="False"
                                            Visibility="Collapsed"/>
                                </Grid>
                            </Grid>
                        </StackPanel>

                        <!-- Container-only settings — disabled when "Directly" is selected.
                             Files / Network / Clipboard / Limits only apply inside the sandbox;
                             in direct mode programs already have full access so these settings
                             have no effect. Approval rules (below) applies to both modes. -->
                        <StackPanel x:Name="ContainerOnlyGroup" Spacing="12">

                        <!-- Files — collapsible -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="False">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Files" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Name="FilesExpanderSummary"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Spacing="8" Padding="0,4">
                                <TextBlock Text="By default, agents only see a temporary workspace folder. Grant access to your user folders below."
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                                <Grid ColumnSpacing="8" RowSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Documents" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="DocsAccessCombo"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnDocsAccessChanged">
                                        <ComboBoxItem Content="Blocked" Tag="None"/>
                                        <ComboBoxItem Content="Read only" Tag="ReadOnly"/>
                                        <ComboBoxItem Content="Read and write" Tag="ReadWrite"/>
                                    </ComboBox>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Downloads" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="DownloadsAccessCombo"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnDownloadsAccessChanged">
                                        <ComboBoxItem Content="Blocked" Tag="None"/>
                                        <ComboBoxItem Content="Read only" Tag="ReadOnly"/>
                                        <ComboBoxItem Content="Read and write" Tag="ReadWrite"/>
                                    </ComboBox>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Desktop" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="DesktopAccessCombo"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnDesktopAccessChanged">
                                        <ComboBoxItem Content="Blocked" Tag="None"/>
                                        <ComboBoxItem Content="Read only" Tag="ReadOnly"/>
                                        <ComboBoxItem Content="Read and write" Tag="ReadWrite"/>
                                    </ComboBox>
                                </Grid>
                                <TextBlock Text="Custom folders"
                                           Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,8,0,0"/>
                                <TextBlock Text="Grant access to specific folders outside the three above. Each grant can be read-only or read-and-write."
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                                <ListView x:Name="CustomFoldersList" SelectionMode="None" MaxHeight="240"
                                          Visibility="Collapsed">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnSpacing="8" Padding="2,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="170"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Path}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           ToolTipService.ToolTip="{Binding Path}"/>
                                                <ComboBox Grid.Column="1"
                                                          HorizontalAlignment="Stretch"
                                                          SelectedIndex="{Binding AccessIndex, Mode=TwoWay}"
                                                          SelectionChanged="OnCustomFolderAccessChanged"
                                                          Tag="{Binding Path}">
                                                    <ComboBoxItem Content="Blocked"/>
                                                    <ComboBoxItem Content="Read only"/>
                                                    <ComboBoxItem Content="Read and write"/>
                                                </ComboBox>
                                                <Button Grid.Column="2" Tag="{Binding Path}"
                                                        Click="OnRemoveCustomFolder"
                                                        Padding="6,2" MinWidth="0"
                                                        ToolTipService.ToolTip="Remove folder">
                                                    <FontIcon Glyph="&#xE894;" FontSize="12"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock x:Name="CustomFoldersEmpty"
                                           Text="No custom folders added."
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Button Content="Add folder…" Click="OnAddCustomFolder" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Expander>

                        <!-- Network — collapsible -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="False">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE839;" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Network" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Name="NetworkExpanderSummary"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Spacing="6" Padding="0,4">
                                <ToggleSwitch x:Name="NetworkToggle"
                                              Header="Allow internet from program code"
                                              OffContent="Off — programs can't reach the internet"
                                              OnContent="On — programs can reach public internet endpoints"
                                              Toggled="OnNetworkToggled"/>
                                <TextBlock Text="When file or clipboard read access is on, programs that reach the internet could send that data outside this PC."
                                           Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Expander>

                        <!-- Clipboard — collapsible -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="False">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE77F;" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Clipboard" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Name="ClipboardExpanderSummary"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Spacing="6" Padding="0,4">
                                <TextBlock Text="Your clipboard often contains passwords, tokens, and private text."
                                           Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <RadioButton x:Name="ClipNoneRadio" Content="None (recommended)" GroupName="Clipboard" Checked="OnClipboardChanged" Tag="None"/>
                                <RadioButton x:Name="ClipReadRadio" Content="Read only — agent can see what you copied" GroupName="Clipboard" Checked="OnClipboardChanged" Tag="Read"/>
                                <RadioButton x:Name="ClipWriteRadio" Content="Write only — agent can replace your clipboard" GroupName="Clipboard" Checked="OnClipboardChanged" Tag="Write"/>
                                <RadioButton x:Name="ClipBothRadio" Content="Read and write" GroupName="Clipboard" Checked="OnClipboardChanged" Tag="Both"/>
                            </StackPanel>
                        </Expander>

                        <!-- Limits — collapsible -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="False">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE916;" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Resource limits" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Name="LimitsExpanderSummary"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Spacing="8" Padding="0,4">
                                <StackPanel Spacing="2">
                                    <TextBlock x:Name="TimeoutLabel" Text="Command timeout: 30 seconds"/>
                                    <Slider x:Name="TimeoutSlider" Minimum="5" Maximum="300" StepFrequency="5"
                                            Value="30" SmallChange="5" LargeChange="15"
                                            ValueChanged="OnTimeoutChanged"/>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Maximum captured output"/>
                                    <ComboBox x:Name="MaxOutputCombo" HorizontalAlignment="Stretch"
                                              SelectionChanged="OnMaxOutputChanged">
                                        <ComboBoxItem Content="1 MB" Tag="1048576"/>
                                        <ComboBoxItem Content="4 MB (default)" Tag="4194304"/>
                                        <ComboBoxItem Content="16 MB" Tag="16777216"/>
                                        <ComboBoxItem Content="64 MB" Tag="67108864"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        </StackPanel>
                        <!-- ─ end ContainerOnlyGroup ─ -->

                        <!-- Approval rules — collapsible -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="False">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE9CE;" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Approval rules" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Name="ApprovalExpanderSummary"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Spacing="6" Padding="0,4">
                                <TextBlock Text="What happens when an agent tries to run a command that doesn't match any rule below:"
                                           Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <ComboBox x:Name="ExecDefaultActionCombo" Width="240"
                                          SelectionChanged="OnExecDefaultActionChanged">
                                    <ComboBoxItem Content="Deny — block unknown commands" Tag="deny"/>
                                    <ComboBoxItem Content="Allow — run unknown commands" Tag="allow"/>
                                    <ComboBoxItem Content="Ask — prompt for each unknown command" Tag="ask"/>
                                </ComboBox>
                                <TextBlock Text="Rules (evaluated top to bottom; first match wins):"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Margin="0,4,0,0"/>
                                <ListView x:Name="ExecRulesList" SelectionMode="None" MaxHeight="280">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="8,6" ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Pattern}" FontFamily="Consolas" VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" CornerRadius="4" Padding="6,2" HorizontalAlignment="Center"
                                                        Background="{Binding ActionBrush}">
                                                    <TextBlock Text="{Binding Action}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                                </Border>
                                                <Button Grid.Column="2" Click="OnRemoveExecRule" Tag="{Binding Index}"
                                                        Padding="4,2" MinWidth="0" Background="Transparent"
                                                        ToolTipService.ToolTip="Remove rule">
                                                    <FontIcon Glyph="&#xE894;" FontSize="12"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBox x:Name="NewExecRulePattern" PlaceholderText="Command pattern (for example: echo *)" Width="320"/>
                                    <ComboBox x:Name="NewExecRuleAction" Width="110" SelectedIndex="0">
                                        <ComboBoxItem Content="allow"/>
                                        <ComboBoxItem Content="deny"/>
                                    </ComboBox>
                                    <Button Content="Add rule" Click="OnAddExecRule"/>
                                </StackPanel>
                                <Button x:Name="SaveExecPolicyButton" Content="Save rules" Click="OnSaveExecPolicy"
                                        Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Browser control -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" HorizontalAlignment="Center" Glyph="&#xE774;" FontSize="20"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Browser control" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="Lets agents open URLs, fill forms, and click links in a browser tab on this PC."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <ToggleSwitch x:Name="BrowserToggle" Grid.Column="2" VerticalAlignment="Center"
                                  OnContent="" OffContent="" MinWidth="0" Toggled="OnBrowserToggled"/>
                </Grid>
            </Border>

            <!-- Canvas -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" HorizontalAlignment="Center" Glyph="&#xE737;" FontSize="20"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Canvas" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="Lets agents show formatted content (text, HTML, A2UI) in a small overlay on this PC."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <ToggleSwitch x:Name="CanvasToggle" Grid.Column="2" VerticalAlignment="Center"
                                  OnContent="" OffContent="" MinWidth="0" Toggled="OnCanvasToggled"/>
                </Grid>
            </Border>

            <!-- Local MCP server -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" HorizontalAlignment="Center" Glyph="&#xE968;" FontSize="20"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Local MCP server" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Exposes this PC's capabilities to local tools (Claude Desktop, Cursor, and similar) over a token-protected HTTP endpoint."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="McpToggle" Grid.Column="2" VerticalAlignment="Center"
                                      OnContent="" OffContent="" MinWidth="0" Toggled="OnMcpToggled"/>
                    </Grid>
                    <StackPanel x:Name="McpDetailPanel" Spacing="10" Margin="40,8,0,0">
                        <!-- Single grid keeps Endpoint and Token rows column-aligned.
                             4 columns: label / value / action1 / action2. The Endpoint
                             row's Copy button sits in column 3 (rightmost), leaving
                             column 2 empty so it aligns with the Token's Copy button. -->
                        <Grid ColumnSpacing="8" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Endpoint row -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Endpoint" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="McpEndpointText"
                                     IsReadOnly="True" FontFamily="Consolas"/>
                            <Button Grid.Row="0" Grid.Column="3" Click="OnCopyMcpUrl"
                                    MinWidth="40"
                                    ToolTipService.ToolTip="Copy URL">
                                <FontIcon Glyph="&#xE8C8;" FontSize="14"/>
                            </Button>

                            <!-- Token row -->
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Token" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="McpTokenText"
                                     Text="•••••••••••••"
                                     IsReadOnly="True" FontFamily="Consolas"/>
                            <Button Grid.Row="1" Grid.Column="2" x:Name="RevealTokenButton"
                                    Click="OnRevealMcpToken"
                                    MinWidth="40"
                                    ToolTipService.ToolTip="Show token for 10 seconds">
                                <FontIcon x:Name="RevealTokenIcon" Glyph="&#xE7B3;" FontSize="14"/>
                            </Button>
                            <Button Grid.Row="1" Grid.Column="3" Click="OnCopyMcpToken"
                                    MinWidth="40"
                                    ToolTipService.ToolTip="Copy token">
                                <FontIcon Glyph="&#xE8C8;" FontSize="14"/>
                            </Button>
                        </Grid>

                        <TextBlock x:Name="McpStatusText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ════════ CAPABILITIES section ════════ -->
            <TextBlock Text="Capabilities"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,16,0,0"/>
            <TextBlock Text="Device-level access — what agents can see, hear, and locate. Each also requires the matching Windows permission."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"/>

            <!-- Camera -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" HorizontalAlignment="Center" Glyph="&#xE722;" FontSize="20"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Camera" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Lets agents capture photos and short clips from your webcam."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="CameraToggle" Grid.Column="2" VerticalAlignment="Center"
                                      OnContent="" OffContent="" MinWidth="0" Toggled="OnCameraToggled"/>
                    </Grid>
                    <StackPanel x:Name="CameraDetailPanel" Spacing="6" Margin="40,0,0,0">
                        <CheckBox x:Name="CameraAlwaysAllowCb" Content="Always allow — don't ask before each use"
                                  Checked="OnCameraAlwaysAllowChanged" Unchecked="OnCameraAlwaysAllowChanged"/>
                        <HyperlinkButton Content="Open Windows camera settings"
                                         Click="OnOpenWindowsCamera" Padding="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Screen capture -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" HorizontalAlignment="Center" Glyph="&#xE7F4;" FontSize="20"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Screen capture" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Lets agents take screenshots and record video of your screen."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="ScreenToggle" Grid.Column="2" VerticalAlignment="Center"
                                      OnContent="" OffContent="" MinWidth="0" Toggled="OnScreenToggled"/>
                    </Grid>
                    <StackPanel x:Name="ScreenDetailPanel" Spacing="6" Margin="40,0,0,0">
                        <CheckBox x:Name="ScreenAlwaysAllowCb" Content="Always allow — don't ask before each recording"
                                  Checked="OnScreenAlwaysAllowChanged" Unchecked="OnScreenAlwaysAllowChanged"/>
                        <HyperlinkButton Content="Open Windows screen recording settings"
                                         Click="OnOpenWindowsScreen" Padding="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Microphone -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" HorizontalAlignment="Center" Glyph="&#xE720;" FontSize="20"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock x:Uid="CapabilitiesPage_SttCardHeader" Text="Microphone" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Uid="CapabilitiesPage_SttCardDescription"
                                       Text="Transcribes microphone audio to text locally on this PC. The speech model downloads once on first use; audio doesn't leave this PC."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="SttToggle" Grid.Column="2" VerticalAlignment="Center"
                                      OnContent="" OffContent="" MinWidth="0" Toggled="OnSttToggled"/>
                    </Grid>
                    <StackPanel x:Name="SttDetailPanel" Spacing="6" Margin="40,0,0,0">
                        <TextBlock x:Name="SttEngineHint"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                        <HyperlinkButton x:Uid="CapabilitiesPage_SttMoreSettingsLink"
                                         Content="More voice settings"
                                         Click="OnSttMoreSettingsClick" Padding="0"/>
                        <HyperlinkButton Content="Open Windows microphone settings"
                                         Click="OnOpenWindowsMic" Padding="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Location -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" HorizontalAlignment="Center" Glyph="&#xE81D;" FontSize="20"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Location" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Lets agents read your approximate location from Windows."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="LocationToggle" Grid.Column="2" VerticalAlignment="Center"
                                      OnContent="" OffContent="" MinWidth="0" Toggled="OnLocationToggled"/>
                    </Grid>
                    <StackPanel x:Name="LocationDetailPanel" Spacing="6" Margin="40,0,0,0">
                        <HyperlinkButton Content="Open Windows location settings"
                                         Click="OnOpenWindowsLocation" Padding="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ════════ GATEWAY section ════════ -->
            <TextBlock Text="From the gateway"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,16,0,0"/>
            <TextBlock Text="Read-only. These are the commands the connected gateway is willing to forward to this PC. Edit them on the gateway side."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"/>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="GatewayAllowlistEmpty"
                               Text="No allowed commands available. Connect to a gateway first."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <ItemsRepeater x:Name="GatewayAllowlistRepeater">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="4"/>
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
